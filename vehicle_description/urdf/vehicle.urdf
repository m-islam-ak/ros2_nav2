<?xml version="1.0"?>
<robot name="robot_car">

  <!-- Root world -->
  <link name="world"/>

  <!-- Chassis -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/chassis.stl"/>
      </geometry>
      <material name="chassis_gray">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="2 1 0.5"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10"/>
      <inertia ixx="1" ixy="0" ixz="0"
               iyy="1" iyz="0"
               izz="1"/>
    </inertial>
  </link>

  <!-- Fix to world so RViz has a stable frame -->
  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Wheel links -->
  <link name="wheel_fl">
    <visual>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/wheel_tire.stl"/>
      </geometry>
      <material name="tire_black">
        <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>
    <visual>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/wheel_rim.stl"/>
      </geometry>
      <material name="rim_gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
  </link>

  <link name="wheel_fr">
    <visual>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/wheel_tire.stl"/>
      </geometry>
      <material name="tire_black"/>
    </visual>
    <visual>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/wheel_rim.stl"/>
      </geometry>
      <material name="rim_gray"/>
    </visual>
  </link>

  <link name="wheel_rl">
    <visual>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/wheel_tire.stl"/>
      </geometry>
      <material name="tire_black"/>
    </visual>
    <visual>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/wheel_rim.stl"/>
      </geometry>
      <material name="rim_gray"/>
    </visual>
  </link>

  <link name="wheel_rr">
    <visual>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/wheel_tire.stl"/>
      </geometry>
      <material name="tire_black"/>
    </visual>
    <visual>
      <geometry>
        <mesh filename="package://vehicle_description/meshes/wheel_rim.stl"/>
      </geometry>
      <material name="rim_gray"/>
    </visual>
  </link>

  <!-- Wheel joints (revolute, GUI-controllable) -->
  <!-- NOTE: wheels are placed at z = -0.25 (bottom of chassis) -->
  <!-- Axis is Y so they spin like a car wheel (if X is forward) -->

  <joint name="wheel_fl_joint" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_fl"/>
    <origin xyz="0.8 0.5 -0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-100" upper="100" effort="10" velocity="10"/>
  </joint>

  <joint name="wheel_fr_joint" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_fr"/>
    <origin xyz="0.8 -0.5 -0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-100" upper="100" effort="10" velocity="10"/>
  </joint>

  <joint name="wheel_rl_joint" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_rl"/>
    <origin xyz="-0.8 0.5 -0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-100" upper="100" effort="10" velocity="10"/>
  </joint>

  <joint name="wheel_rr_joint" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_rr"/>
    <origin xyz="-0.8 -0.5 -0.25" rpy="0 1 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-100" upper="100" effort="10" velocity="10"/>
  </joint>

</robot>
